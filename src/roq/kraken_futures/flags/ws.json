{
  "name": "roq/kraken_futures/flags/WS",
  "type": "flags",
  "prefix": "ws_",
  "values": [
    {
      "name": "uri",
      "type": "roq/io/web/URI",
      "validator": "roq::core::flags::URI",
      "default": "wss://demo-futures.kraken.com/ws/v3",
      "description": "Exchange end-point"
    },
    {
      "name": "ping_freq",
      "type": "std/nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "5s",
      "description": "Ping frequency"
    },
    {
      "name": "request_timeout",
      "type": "std/nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "15s",
      "description": "Request timeout"
    },
    {
      "name": "max_subscriptions_per_stream",
      "type": "std/uint32",
      "required": true,
      "default": 128,
      "description": "Maximum number of symbols per connection"
    }
  ]
}
