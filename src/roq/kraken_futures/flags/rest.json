{
  "name": "roq/kraken_futures/flags/REST",
  "type": "flags",
  "prefix": "rest_",
  "values": [
    {
      "name": "uri",
      "type": "roq/io/web/URI",
      "validator": "roq::core::flags::URI",
      "default": "https://demo-futures.kraken.com/derivatives",
      "description": "Exchange end-point"
    },
    {
      "name": "proxy",
      "type": "roq/io/web/URI",
      "validator": "roq::core::flags::URI",
      "description": "Proxy end-point"
    },
    {
      "name": "ping_freq",
      "type": "std/nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "5s",
      "description": "Ping frequency"
    },
    {
      "name": "ping_path",
      "type": "std/string",
      "validator": "roq::flags::validators::Path",
      "default": "/api/v3/instruments",
      "description": "Ping path"
    },
    {
      "name": "cancel_on_disconnect",
      "type": "std/bool",
      "default": true,
      "description": "Cancel orders on disconnect?"
    },
    {
      "name": "cancel_all_after",
      "type": "std/nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "30s",
      "description": "Cancel all after, requires cancel-on-disconnect"
    },
    {
      "name": "request_timeout",
      "type": "std/nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "30s",
      "description": "Request timeout"
    },
    {
      "name": "allow_order_request_pipeline",
      "type": "std/bool",
      "default": false,
      "description": "Allow more than one in-flight order action?"
    },
    {
      "name": "use_nonce",
      "type": "std/bool",
      "default": "true",
      "description": "Use nonce for security?"
    }
  ]
}
