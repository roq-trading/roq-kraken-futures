{
  "name": "Flags",
  "type": "flags",
  "values": [
    {
      "name": "config_file",
      "type": "std::string",
      "validator": "roq::core::flags::Path<std::string>",
      "description": "config file (path)"
    },
    {
      "name": "exchange",
      "type": "std::string",
      "validator": "roq::core::flags::NonEmpty<std::string>",
      "default": "kraken",
      "description": "exchange identifier (string)"
    },
    {
      "name": "rest_uri",
      "type": "roq::core::URI",
      "validator": "roq::core::flags::URI<std::string>",
      "default": "https://demo-futures.kraken.com/derivatives",
      "description": "REST end-point (URI)"
    },
    {
      "name": "rest_ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "5s",
      "description": "ping frequency"
    },
    {
      "name": "rest_ping_path",
      "type": "std::string",
      "validator": "roq::core::flags::Path<std::string>",
      "default": "/api/v3/instruments",
      "description": "URI path used for REST connection keep-alive messages"
    },
    {
      "name": "rest_request_timeout",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "30s",
      "description": "request: timeout"
    },
    {
      "name": "rest_rate_limit_interval",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "1s",
      "description": "rate limit: monitor interval (seconds)"
    },
    {
      "name": "rest_rate_limit_max_requests",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 300,
      "description": "rate limit: max requests (per interval)"
    },
    {
      "name": "ws_uri",
      "type": "roq::core::URI",
      "validator": "roq::core::flags::URI<std::string>",
      "default": "wss://demo-futures.kraken.com/ws/v1",
      "description": "WebSocket end-point (URI)"
    },
    {
      "name": "ws_ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "5s",
      "description": "ping frequency"
    },
    {
      "name": "ws_request_timeout",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "15s",
      "description": "request timeout"
    },
    {
      "name": "ws_subscribe_book_depth",
      "type": "uint32_t",
      "validator": "roq::core::flags::Positive<uint32_t>",
      "default": 10,
      "description": "book depth (size)"
    },
    {
      "name": "ws_max_subscriptions_per_stream",
      "type": "uint32_t",
      "validator": "roq::core::flags::Positive<uint32_t>",
      "default": 128,
      "description": "max subscriptions per connection (count)"
    },
    {
      "name": "encode_buffer_size",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 1048576,
      "description": "encode buffer size"
    },
    {
      "name": "decode_buffer_size",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 10485760,
      "description": "decode buffer size"
    }
  ]
}
