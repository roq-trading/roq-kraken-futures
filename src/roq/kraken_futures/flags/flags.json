{
  "name": "Flags",
  "type": "flags",
  "values": [
    {
      "name": "config_file",
      "type": "std::string",
      "validator": "roq::core::flags::Path<std::string>",
      "description": "config file (path)"
    },
    {
      "name": "secrets_file",
      "type": "std::string",
      "validator": "roq::core::flags::Path<std::string>",
      "description": "secrets file (path, optional)"
    },
    {
      "name": "exchange",
      "type": "std::string",
      "validator": "roq::core::flags::NonEmpty<std::string>",
      "default": "kraken-futures",
      "description": "exchange identifier (string)"
    },
    {
      "name": "rest_uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI<std::string>",
      "default": "https://demo-futures.kraken.com/derivatives",
      "description": "REST end-point (URI)"
    },
    {
      "name": "rest_proxy",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI<std::string>",
      "description": "proxy end-point (URI)"
    },
    {
      "name": "rest_ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "5s",
      "description": "ping frequency"
    },
    {
      "name": "rest_ping_path",
      "type": "std::string",
      "validator": "roq::core::flags::Path<std::string>",
      "default": "/api/v3/instruments",
      "description": "URI path used for REST connection keep-alive messages"
    },
    {
      "name": "rest_cancel_on_disconnect",
      "type": "bool",
      "default": true,
      "description": "cancel orders on disconnect? (bool)"
    },
    {
      "name": "rest_cancel_all_after",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "30s",
      "description": "cancel all after, requires cancel-on-disconnect"
    },
    {
      "name": "rest_request_timeout",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "30s",
      "description": "request: timeout"
    },
    {
      "name": "rest_allow_order_request_pipeline",
      "type": "bool",
      "default": false,
      "description": "allow more than one in-flight order action? (bool)"
    },
    {
      "name": "rest_use_nonce",
      "type": "bool",
      "default": "true",
      "description": "use nonce for security?"
    },
    {
      "name": "ws_uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI<std::string>",
      "default": "wss://demo-futures.kraken.com/ws/v3",
      "description": "WebSocket end-point (URI)"
    },
    {
      "name": "ws_ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "5s",
      "description": "ping frequency"
    },
    {
      "name": "ws_request_timeout",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "15s",
      "description": "request timeout"
    },
    {
      "name": "ws_max_subscriptions_per_stream",
      "type": "uint32_t",
      "validator": "roq::core::flags::Positive<uint32_t>",
      "default": 128,
      "description": "max subscriptions per connection (count)"
    },
    {
      "name": "encode_buffer_size",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 1048576,
      "description": "encode buffer size"
    },
    {
      "name": "decode_buffer_size",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 10485760,
      "description": "decode buffer size"
    },
    {
      "name": "mbp_allow_price_inversion",
      "type": "bool",
      "default": false,
      "description": "allow price inversion?"
    }
  ]
}
